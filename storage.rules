rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Publicly readable so our Next.js frontend can serve the gallery videos/audio to any visitor 
      allow read: if true;
      
      // Only authenticated users can upload/modify/delete files
      allow write: if request.auth != null;
    }
  }
}
