rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is in the admins collection
    function isAdmin() {
      return request.auth != null
          && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Admins collection ────────────────────────────────────────────────────
    // Only admins can read (to verify their own status); no client-side writes
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Portfolio collections + items ────────────────────────────────────────
    match /portfolio_collections/{collectionId} {
      allow read: if true;          // public gallery
      allow write: if isAdmin();

      match /items/{itemId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // ── Published gallery (public snapshot) ──────────────────────────────────
    match /published_gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Work-Contact services + items ────────────────────────────────────────
    match /workcontact_services/{categoryId} {
      allow read: if true;          // public services page
      allow write: if isAdmin();

      match /items/{itemId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // ── Work-Contact config ──────────────────────────────────────────────────
    match /workcontact_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Default deny ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
